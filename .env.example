# Hypostasia — Variables d'environnement

# --- Domaine et securite ---
DOMAIN=hypo.nasjo.fr
SECRET_KEY=CHANGEZ_MOI_EN_PROD
DEBUG=false

# --- UID/GID du container (doit matcher l'utilisateur hote pour les volumes) ---
# Trouver votre UID/GID : id -u && id -g
UID=1000
GID=1000

# --- Base de donnees PostgreSQL ---
POSTGRES_DB=hypostasia
POSTGRES_USER=hypostasia
POSTGRES_PASSWORD=CHANGEZ_MOI_EN_PROD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Nginx (dev.conf pour dev, default.conf pour prod) ---
NGINX_CONF=default.conf

# --- Redis / Celery / Django Channels ---
CELERY_BROKER_URL=redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

# --- Cles API (fallback si le champ DB est vide) ---
# Les cles peuvent aussi etre configurees dans l'admin Django (AIModel / TranscriptionConfig).
# La priorite est : champ DB > variable d'environnement.
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
OLLAMA_API_KEY=

# --- Stripe (credits prepays pour les analyses LLM) ---
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Email ---
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
